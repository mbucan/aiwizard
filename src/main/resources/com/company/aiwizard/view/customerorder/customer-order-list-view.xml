<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://customerOrderListView.title"
      focusComponent="customerOrdersDataGrid">
    <data>
        <collection id="customerOrdersDc"
                    class="com.company.aiwizard.entity.CustomerOrder">
            <fetchPlan extends="_base">
                <property name="customer" fetchPlan="_base"/>
                <property name="product" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="customerOrdersDl" readOnly="true">
                <query>
                    <![CDATA[select e from CustomerOrder e order by e.orderDate desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="customerOrdersDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <startSlot>
                <button id="createButton" action="customerOrdersDataGrid.createAction"/>
                <button id="editButton" action="customerOrdersDataGrid.editAction"/>
                <button id="removeButton" action="customerOrdersDataGrid.removeAction"/>
                <button id="populateButton" text="Populate with data"/>
            </startSlot>
            <endSlot>
                <simplePagination id="pagination" dataLoader="customerOrdersDl"/>
            </endSlot>
        </hbox>
        <dataGrid id="customerOrdersDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="customerOrdersDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="orderNumber"/>
                <column property="customer"/>
                <column property="product"/>
                <column property="quantity"/>
                <column property="totalAmount"/>
                <column property="orderDate"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
